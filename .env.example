# daily_push_bot.py 配置文件
# 复制为 .env 后按需修改，部署时只需改 .env 无需改代码

# 飞书机器人 Webhook（必填）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx

# 卡片标题（可选，默认：每日市场雷达）
FEISHU_CARD_TITLE=每日市场雷达

# 卡片标题栏样式（可选：blue/red/green/orange/grey，默认：blue）
FEISHU_CARD_HEADER_TEMPLATE=blue

# 财联社搜索关键词，用于抓取「行业热点」正文（可选，默认：今日投资舆情热点）
CLS_KEYWORD=今日投资舆情热点

# 指数产品 txt 路径，相对项目目录或绝对路径（可选，默认：index_products.txt）
INDEX_PRODUCTS_TXT=index_products.txt

# 产品名称列超过多少字换行（可选，默认：18）
PRODUCT_NAME_WRAP_WIDTH=18
